# Clave para firmar JWT. Obligatoria en producción.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=cambiame-en-produccion-genera-una-larga-y-aleatoria

# Orígenes permitidos por CORS, separados por coma.
# Ej: https://hokosocial.vercel.app,https://hokosocial-git-main-perkiins.vercel.app
CORS_ORIGINS=https://hokosocial.vercel.app

# Clave compartida con el worker local. Obligatoria si usas tareas reales
# (search/followback). Endpoints /api/worker/* la exigen como header X-Worker-Key.
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(40))"
WORKER_API_KEY=

# --- Pagos / Stripe (opcional) ---
# Sin estas variables el sistema funciona pero los endpoints de pago devuelven 503.
# Test mode: empieza con sk_test_... y whsec_test_... desde dashboard.stripe.com.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URL del frontend (para redirect tras Stripe Checkout).
FRONTEND_URL=https://hokosocial.vercel.app

# Modo debug (true sólo en local).
FLASK_DEBUG=false

# Puerto local (Render inyecta su propio PORT).
PORT=5000
